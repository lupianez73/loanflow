# ── Local development ────────────────────────────────────────────────
# SQLite file — works out of the box, no setup needed
DATABASE_URL="file:./prisma/dev.db"

# Any string ≥ 32 chars for local dev
JWT_SECRET="dev-secret-change-in-production-min-32-chars"

NODE_ENV="development"

# ── Production (Vercel + Turso) ──────────────────────────────────────
# 1. Create a free Turso database:
#      npx turso auth login
#      npx turso db create loanflow
#
# 2. Get the connection URL:
#      npx turso db show loanflow --url
#    → libsql://loanflow-<user>.turso.io
#
# 3. Create an auth token:
#      npx turso db tokens create loanflow
#
# 4. Set on Vercel:
#      DATABASE_URL=libsql://loanflow-<user>.turso.io?authToken=<TOKEN>
#
# DATABASE_URL="libsql://loanflow-<user>.turso.io?authToken=<TOKEN>"

# Generate a strong secret (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET="<64-char-random-hex>"
